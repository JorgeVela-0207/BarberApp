<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BarberApp.Views.LoginPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{DynamicResource PageBackground}">

    <Grid>
        <BoxView Color="{DynamicResource GlowGold}" Opacity="0.5"
                 HorizontalOptions="End" VerticalOptions="Start"
                 WidthRequest="200" HeightRequest="200" Margin="0,-40,-40,0"/>

        <Border Style="{StaticResource AuthCard}">
            <VerticalStackLayout Spacing="18">
                <HorizontalStackLayout HorizontalOptions="Center" Spacing="8">
                    <Border BackgroundColor="{DynamicResource AccentGoldSoft}" StrokeThickness="0" Padding="10,6">
                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                        <Label Text="✦" FontSize="20" TextColor="{DynamicResource AccentGold}"/>
                    </Border>
                    <Label Text="✂" FontSize="36" TextColor="{DynamicResource AccentGold}" VerticalOptions="Center"/>
                </HorizontalStackLayout>

                <Label Text="BarberApp" TextColor="{DynamicResource TextPrimary}"
                       FontSize="28" FontAttributes="Bold" HorizontalOptions="Center"/>
                <Label Text="Salones · Barberías · Estéticas"
                       TextColor="{DynamicResource TextMuted}" FontSize="12" HorizontalOptions="Center"/>

                <Label x:Name="LblNombreLocal" TextColor="{DynamicResource TextSecondary}"
                       FontSize="13" HorizontalOptions="Center"/>
                <Label x:Name="LblAvisoLicencia" IsVisible="False"
                       TextColor="{DynamicResource BannerWarningText}" FontSize="12"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>

                <BoxView Style="{StaticResource AppDivider}"/>

                <Border Style="{StaticResource AppInputBorder}">
                    <Entry x:Name="EntryUsuario" Placeholder="Usuario"
                           PlaceholderColor="{DynamicResource TextMuted}"
                           TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent"/>
                </Border>

                <Border Style="{StaticResource AppInputBorder}">
                    <Entry x:Name="EntryPassword" Placeholder="Contraseña" IsPassword="True"
                           PlaceholderColor="{DynamicResource TextMuted}"
                           TextColor="{DynamicResource TextPrimary}" BackgroundColor="Transparent"/>
                </Border>

                <Label x:Name="LblError" Text="Usuario o contraseña incorrectos"
                       TextColor="#e05555" FontSize="12" IsVisible="False" HorizontalOptions="Center"/>

                <Button Text="Entrar" Clicked="OnEntrarClicked" Style="{StaticResource AppPrimaryButton}"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>
